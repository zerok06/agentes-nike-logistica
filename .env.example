# ==============================================================
# .env.example — Nike Logística Platform
# PLANTILLA sin secretos — SÍ se sube al repositorio
#
# Uso:
#   cp .env.example .env
#   Edita .env con tus valores reales antes de hacer docker compose up
# ==============================================================


# ==============================================================
# DB 1 — CENTRAL (Plataforma SaaS)  →  puerto 5432
# ==============================================================
DB_CENTRAL_USER=nike_admin
DB_CENTRAL_PASSWORD=REEMPLAZA_PASSWORD_CENTRAL
DB_CENTRAL_NAME=nike_logistica_db
DB_CENTRAL_HOST=localhost
DB_CENTRAL_PORT=5432

DATABASE_URL_CENTRAL=postgresql+asyncpg://nike_admin:REEMPLAZA_PASSWORD_CENTRAL@localhost:5432/nike_logistica_db
DATABASE_URL_CENTRAL_SYNC=postgresql://nike_admin:REEMPLAZA_PASSWORD_CENTRAL@localhost:5432/nike_logistica_db


# ==============================================================
# DB 2 — SEDE PERU (Operaciones Logísticas)  →  puerto 5433
# ==============================================================
DB_SEDE_USER=sede_admin
DB_SEDE_PASSWORD=REEMPLAZA_PASSWORD_SEDE
DB_SEDE_NAME=nike_sede_peru_db
DB_SEDE_HOST=localhost
DB_SEDE_PORT=5433

DATABASE_URL_SEDE=postgresql+asyncpg://sede_admin:REEMPLAZA_PASSWORD_SEDE@localhost:5433/nike_sede_peru_db
DATABASE_URL_SEDE_SYNC=postgresql://sede_admin:REEMPLAZA_PASSWORD_SEDE@localhost:5433/nike_sede_peru_db


# ==============================================================
# DB 3 — RETAIL (Distribuidoras)  →  puerto 5434
# ==============================================================
DB_RETAIL_USER=retail_admin
DB_RETAIL_PASSWORD=REEMPLAZA_PASSWORD_RETAIL
DB_RETAIL_NAME=nike_retail_db
DB_RETAIL_HOST=localhost
DB_RETAIL_PORT=5434

DATABASE_URL_RETAIL=postgresql+asyncpg://retail_admin:REEMPLAZA_PASSWORD_RETAIL@localhost:5434/nike_retail_db
DATABASE_URL_RETAIL_SYNC=postgresql://retail_admin:REEMPLAZA_PASSWORD_RETAIL@localhost:5434/nike_retail_db


# ==============================================================
# DB 4 — SUPPLY CHAIN (Fábricas)  →  puerto 5435
# ==============================================================
DB_SUPPLY_USER=supply_admin
DB_SUPPLY_PASSWORD=REEMPLAZA_PASSWORD_SUPPLY
DB_SUPPLY_NAME=nike_supply_chain_db
DB_SUPPLY_HOST=localhost
DB_SUPPLY_PORT=5435

DATABASE_URL_SUPPLY=postgresql+asyncpg://supply_admin:REEMPLAZA_PASSWORD_SUPPLY@localhost:5435/nike_supply_chain_db
DATABASE_URL_SUPPLY_SYNC=postgresql://supply_admin:REEMPLAZA_PASSWORD_SUPPLY@localhost:5435/nike_supply_chain_db


# ==============================================================
# REDIS  →  puerto 6379
# ==============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=REEMPLAZA_PASSWORD_REDIS
REDIS_DB=0
REDIS_URL=redis://:REEMPLAZA_PASSWORD_REDIS@localhost:6379/0


# ==============================================================
# pgADMIN (http://localhost:5050)  →  --profile tools
# ==============================================================
PGADMIN_EMAIL=admin@tudominio.com
PGADMIN_PASSWORD=REEMPLAZA_PASSWORD_PGADMIN
PGADMIN_PORT=5050


# ==============================================================
# FastAPI
# ==============================================================
APP_ENV=development
APP_PORT=8000
APP_HOST=0.0.0.0

SECRET_KEY=REEMPLAZA_CON_STRING_ALEATORIO_32_CHARS_MINIMO
DEMO_MODE=True
DEMO_ROLE_HEADER=X-Demo-Role
CORS_ORIGINS=http://localhost:3000,http://localhost:5173


# ==============================================================
# GROQ API  →  https://console.groq.com/keys
# ==============================================================
GROQ_API_KEY=gsk_REEMPLAZA_CON_TU_CLAVE_GROQ
GROQ_MODEL=llama3-8b-8192
GROQ_MAX_TOKENS=2048
GROQ_TEMPERATURE=0.3


# ==============================================================
# KEYCLOAK (solo producción — deshabilitado en DEMO_MODE=True)
# ==============================================================
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=nike-logistica
KEYCLOAK_CLIENT_ID=nike-backend
KEYCLOAK_CLIENT_SECRET=REEMPLAZA_CON_SECRET_KEYCLOAK
KEYCLOAK_ALGORITHM=RS256


# ==============================================================
# SENTENCETRANSFORMERS
# ==============================================================
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384
VECTOR_SIMILARITY_THRESHOLD=0.95
