# ==============================================================
# .gitignore — Nike Logística Platform
# ==============================================================

# ---- Secretos y credenciales (NUNCA subir al repo) ----
.env
*.env.local
*.env.production
*.env.staging
secrets/
*.pem
*.key
*.crt

# ---- Docker ----
# Los volúmenes son locales, no se versionan
docker-compose.override.yml

# ---- Python / FastAPI ----
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
.Python
env/
venv/
.venv/
ENV/
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/
*.whl

# ---- Pytest / Coverage ----
.pytest_cache/
.coverage
htmlcov/
.tox/
coverage.xml
*.coveragerc

# ---- Mypy / Ruff / Pylint ----
.mypy_cache/
.ruff_cache/
.pylint.d/

# ---- Node / Frontend ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dist/
.next/
out/
.nuxt/
.cache/

# ---- IDEs y editores ----
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---- Logs ----
*.log
logs/
*.log.*

# ---- Jupyter Notebooks (checkpoints) ----
.ipynb_checkpoints/

# ---- Modelos ML / Embeddings (grandes, no versionar) ----
*.bin
*.safetensors
sentence_transformers/
huggingface_cache/
.cache/huggingface/

# ---- Archivos temporales ----
tmp/
temp/
*.tmp
*.bak
*.backup
